{
  "name": "healthflux",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --quiet",
    "typecheck": "tsc -p ./jsconfig.json",
    "api": "node api/server.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run api\"",
    "cap:init": "npx cap init HealthFlux com.healthfluxi.app --web-dir dist",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android",
    "mobile:setup": "npm run build && npx cap add ios && npx cap add android && npx cap sync",
    "mobile:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "mobile:android": "npm run build && npx cap sync android && npx cap open android",
    "deploy": "bash deploy.sh"
  },
